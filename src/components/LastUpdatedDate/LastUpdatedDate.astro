---
/**
 * LastUpdatedDate — the visible freshness signal under every H1.
 *
 * Reads the ISO date from the `date` prop and formats with Australian locale:
 * "Last updated: April 2026". Real DOM text, not CSS — required for the
 * crawler-visible freshness signal that ranking algorithms read.
 *
 * Register: a 12px mono caps "Last updated:" label in Ink-2 followed by the
 * date as a 12px Public Sans Ink-3 value in all caps (e.g. NOVEMBER 2026),
 * matching the verification-family label/value pairing. Sized at the 12px
 * small-text floor and kept off Ink-4 because the date is meaningful content
 * (a freshness signal), not decoration, and must clear WCAG AA.
 *
 * Locked decisions reflected here:
 *   #6 — `lastUpdated` always comes from frontmatter, never git.
 */

interface Props {
  /** ISO date YYYY-MM-DD from frontmatter. */
  date: string;
}

const { date } = Astro.props;

const formatted = new Date(date)
  .toLocaleDateString('en-AU', {
    year: 'numeric',
    month: 'long',
  })
  .toUpperCase();
---

<p class="last-updated">
  <span class="last-updated__label t-label">Last updated:</span>
  <time class="last-updated__value" datetime={date}>{formatted}</time>
</p>

<style>
  /* Label — mono caps (via t-label) at 12px, Ink-2 (clears AA). */
  .last-updated__label {
    color: var(--color-ink-2);
    font-size: 12px;
    margin-right: 0.4em;
  }
  /* Value — Public Sans 12px, Ink-3, uppercased (all caps). */
  .last-updated__value {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.5;
    color: var(--color-ink-3);
  }
</style>
