---
import LastUpdatedDate from './LastUpdatedDate.astro';

const samples = [
  { iso: '2026-04-28', label: 'NSW Owner Builder page (April 2026)' },
  { iso: '2026-05-19', label: 'Today' },
  { iso: '2025-11-03', label: 'A stale page (5+ months old)' },
];
---

<div class="space-y-6">
  {
    samples.map((s) => (
      <section>
        <h3 class="t-label" style="color: var(--color-ink-3);">
          {s.label}
        </h3>
        <div
          class="mt-2 px-5 py-4"
          style="border: 1px solid var(--color-rule); background: var(--color-bg);"
        >
          <LastUpdatedDate date={s.iso} />
          <p
            class="t-body mt-2"
            style="color: var(--color-ink-3); font-size: 13px;"
          >
            Input: <code>date="{s.iso}"</code>
          </p>
        </div>
      </section>
    ))
  }
</div>
