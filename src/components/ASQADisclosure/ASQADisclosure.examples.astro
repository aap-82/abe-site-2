---
import ASQADisclosure from './ASQADisclosure.astro';
import type { DisclosureContext } from '@data/disclosures/asqa-templates';

const context: DisclosureContext = {
  enrolPartner: 'ABE Education',
  enrolPartnerLegal: 'ABE Education Pty Ltd',
  enrolPartnerAbn: '64 125 455 272',
  rto: 'AlertForce',
  rtoLegal: 'AlertForce Pty Ltd',
  rtoCode: '91826',
  courseName: 'NSW Owner Builder Course',
  courseShort: 'NSW Owner Builder',
  unitCodes: ['CPCCWHS2001', 'CPCCOM2001', 'CPCCCM1011', 'CPCCOM1013', 'CPCCOM1014'],
  permitName: 'Owner Builder Permits',
  permitRegulator: 'Building Commission NSW',
  permitAct: 'Home Building Act 1989',
  permitApplicationBody: 'Service NSW',
  termsHref: '/terms',
};
---

<div class="space-y-10">
  <section>
    <h3 class="t-label" style="color: var(--color-ink-3);">
      near-cta — disclosure beside a call to action (canonical)
    </h3>
    <p class="t-body mt-2" style="color: var(--color-ink-2); font-size: 14px; max-width: 70ch;">
      The verbatim approved template that must sit near every CTA on an
      RTO-partnered page.
    </p>
    <div class="mt-3 px-6 py-6" style="border: 1px solid var(--color-rule); background: var(--color-bg);">
      <ASQADisclosure variant="near-cta" context={context} />
    </div>
  </section>

  <section>
    <h3 class="t-label" style="color: var(--color-ink-3);">
      footer-legal — the "About this course" block
    </h3>
    <p class="t-body mt-2" style="color: var(--color-ink-2); font-size: 14px; max-width: 70ch;">
      Three approved paragraphs; the Terms &amp; Conditions reference is linked.
    </p>
    <div class="mt-3 px-6 py-6" style="border: 1px solid var(--color-rule); background: var(--color-bg);">
      <ASQADisclosure variant="footer-legal" context={context} />
    </div>
  </section>

  <section>
    <h3 class="t-label" style="color: var(--color-ink-3);">
      copyright-bar — the 3-line structured format
    </h3>
    <p class="t-body mt-2" style="color: var(--color-ink-2); font-size: 14px; max-width: 70ch;">
      Course, training provider, and enrolment partner, in Geist Mono.
    </p>
    <div class="mt-3 px-6 py-6" style="border: 1px solid var(--color-rule); background: var(--color-bg);">
      <ASQADisclosure variant="copyright-bar" context={context} />
    </div>
  </section>
</div>
