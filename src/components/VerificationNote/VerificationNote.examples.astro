---
import VerificationNote from './VerificationNote.astro';
---

<div class="space-y-10">
  <!-- One-line — single source -->
  <section>
    <h3 class="t-label" style="color: var(--color-ink-3);">
      One-line — single source (canonical)
    </h3>
    <p
      class="t-body mt-2"
      style="color: var(--color-ink-2); font-size: 14px; max-width: 70ch;"
    >
      Right-aligned structured stamp. Both labels inline; the date stays
      mixed-case. 1px Rule line above.
    </p>
    <div
      class="mt-3 px-6 py-6"
      style="border: 1px solid var(--color-rule); background: var(--color-bg);"
    >
      <p class="t-body" style="color: var(--color-ink-2); max-width: 70ch;">
        <em>(compact card body content sits here)</em>
      </p>
      <VerificationNote lastVerified="2026-05-19">
        <a href="https://www.qbcc.qld.gov.au/" class="link-dotted" rel="external">QBCC</a>
      </VerificationNote>
    </div>
  </section>

  <!-- One-line — multiple sources, bullet-separated -->
  <section>
    <h3 class="t-label" style="color: var(--color-ink-3);">
      One-line — multiple sources, bullet-separated
    </h3>
    <p
      class="t-body mt-2"
      style="color: var(--color-ink-2); font-size: 14px; max-width: 70ch;"
    >
      Multiple sources joined with a double-spaced <code>•</code> bullet. The
      VERIFIED ON label and date follow the last source.
    </p>
    <div
      class="mt-3 px-6 py-6"
      style="border: 1px solid var(--color-rule); background: var(--color-bg);"
    >
      <p class="t-body" style="color: var(--color-ink-2); max-width: 70ch;">
        <em>(compact card body content sits here)</em>
      </p>
      <VerificationNote lastVerified="2026-05-01">
        <a href="https://training.gov.au/Organisation/Details/31193" class="link-dotted" rel="external">RTO 31193</a>
        <span class="eg-bullet" aria-hidden="true">•</span>
        <a href="https://training.gov.au/Organisation/Details/91826" class="link-dotted" rel="external">RTO 91826</a>
        <span class="eg-bullet" aria-hidden="true">•</span>
        <a href="https://www.qbcc.qld.gov.au/" class="link-dotted" rel="external">QBCC</a>
      </VerificationNote>
    </div>
  </section>
</div>

<style>
  /* Bullet separator for multi-source — double-space gap each side. */
  .eg-bullet {
    display: inline-block;
    margin: 0 0.5em;
    font-size: 12px;
    color: var(--color-ink-4);
  }
</style>
