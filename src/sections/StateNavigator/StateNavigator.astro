---
/**
 * StateNavigator — the choose-your-state navigator.
 *
 * Analysis §2.2 / §3.4: the "Choose your state" block on hub and homepage.
 * Lists the states ABE serves, each linking down to its course spoke page.
 * Two layouts via the `variant` prop:
 *
 *   grid  — a responsive grid of state cards (homepage and hub default).
 *   table — a State / Regulator / Course row table (dense hub listing).
 *
 * This is a NAVIGATION component — every state links to its spoke page.
 * For attribute-by-option data comparison use ComparisonTable instead.
 *
 * Locked decisions reflected here:
 *   #1 — heading is a prop; the component renders its own <h2>.
 *   #7 — wrapper id auto-generates from slugify(heading).
 */
import { slugify } from '@/lib/slugify';

interface StateEntry {
  /** State or territory name, e.g. "New South Wales". */
  name: string;
  /** The regulator that approves the course there, e.g. "QBCC". */
  regulator: string;
  /** Link to the state course spoke page. */
  href: string;
  /** One-line course detail, e.g. "Required for work over $5,000". */
  detail: string;
}

interface Props {
  /** The section H2. */
  heading: string;
  /** Layout — grid of cards, or a dense row table. */
  variant?: 'grid' | 'table';
  /** The states ABE serves. */
  states: StateEntry[];
  anchorId?: string;
}

const { heading, variant = 'grid', states, anchorId } = Astro.props;
const id = anchorId ?? slugify(heading);
---

<section id={id} class="snav-section" aria-labelledby={`${id}-label`}>
  <h2 id={`${id}-label`} class="t-headline snav__heading">{heading}</h2>

  {
    variant === 'grid' ? (
      <ul class="snav__grid">
        {states.map((s) => (
          <li>
            <a class="snav__card" href={s.href}>
              <span class="snav__reg">{s.regulator}</span>
              <span class="snav__name">{s.name}</span>
              <span class="snav__detail">{s.detail}</span>
              <span class="snav__go">
                View course
                <span class="snav__arrow" aria-hidden="true">→</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="snav__scroll">
        <table class="snav__table">
          <thead>
            <tr>
              <th scope="col">State</th>
              <th scope="col">Regulator</th>
              <th scope="col">Course</th>
            </tr>
          </thead>
          <tbody>
            {states.map((s) => (
              <tr>
                <th scope="row" class="snav__td-state">{s.name}</th>
                <td>{s.regulator}</td>
                <td>
                  <a class="link-dotted" href={s.href}>{s.detail}</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
</section>

<style>
  .snav-section {
    scroll-margin-top: var(--spacing-xl);
  }
  .snav__heading {
    color: var(--color-ink);
    margin: 0 0 var(--spacing-lg);
  }

  /* --- Grid variant --- */
  .snav__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1px;
    background: var(--color-rule);
    border: 1px solid var(--color-rule);
  }
  .snav__card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    padding: var(--spacing-lg);
    background: var(--color-bg);
    text-decoration: none;
    height: 100%;
  }
  .snav__reg {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-info-deep);
  }
  .snav__name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.0625rem;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-ink);
  }
  .snav__detail {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-ink-2);
    flex: 1 1 auto;
  }
  .snav__go {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-top: var(--spacing-xs);
  }
  .snav__arrow {
    display: inline-block;
    margin-left: 0.4em;
    transition: transform 180ms ease;
  }
  .snav__card:hover {
    background: var(--color-bg-alt);
  }
  .snav__card:hover .snav__go {
    color: var(--color-accent-deep);
  }
  .snav__card:hover .snav__arrow {
    transform: translateX(3px);
  }
  .snav__card:focus-visible {
    outline: 2px solid var(--color-ink);
    outline-offset: -3px;
  }

  /* --- Table variant --- */
  .snav__scroll {
    overflow-x: auto;
  }
  .snav__table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }
  .snav__table th[scope="col"] {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-3);
    padding: var(--spacing-xs) var(--spacing-md) var(--spacing-xs) 0;
    border-bottom: 1px solid var(--color-ink);
  }
  .snav__table td,
  .snav__table th[scope="row"] {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-ink);
    padding: var(--spacing-sm) var(--spacing-md) var(--spacing-sm) 0;
    border-bottom: 1px solid var(--color-rule);
    vertical-align: top;
  }
  .snav__td-state {
    font-weight: 600;
    white-space: nowrap;
  }
  .snav__table td:nth-child(2) {
    color: var(--color-ink-2);
    white-space: nowrap;
  }
</style>
