---
import StateNavigator from './StateNavigator.astro';

const states = [
  {
    name: 'New South Wales',
    regulator: 'NSW Fair Trading',
    href: '/owner-builder-nsw',
    detail: 'Delivered by AlertForce (RTO 91826); five nationally recognised units.',
  },
  {
    name: 'Queensland',
    regulator: 'QBCC',
    href: '/owner-builder-qld',
    detail: 'Required for residential work valued over $11,000.',
  },
  {
    name: 'Western Australia',
    regulator: 'Consumer Protection WA',
    href: '/owner-builder-wa',
    detail: 'Meets the Building Services Board education requirement.',
  },
  {
    name: 'Tasmania',
    regulator: 'CBOS Tasmania',
    href: '/owner-builder-tas',
    detail: 'Required for owner-builder work valued over $5,000.',
  },
  {
    name: 'Australian Capital Territory',
    regulator: 'Access Canberra',
    href: '/owner-builder-act',
    detail: 'Meets Section 32 owner-builder eligibility.',
  },
];

const stateLinks = [
  {
    name: 'New South Wales',
    courses: [
      { label: 'White Card NSW', href: '/white-card-nsw' },
      { label: 'Owner Builder NSW', href: '/owner-builder-nsw' },
    ],
  },
  {
    name: 'Queensland',
    courses: [
      { label: 'White Card QLD', href: '/white-card-qld' },
      { label: 'Owner Builder QLD', href: '/owner-builder-qld' },
    ],
  },
  {
    name: 'Western Australia',
    courses: [
      { label: 'White Card WA', href: '/white-card-wa' },
      { label: 'Owner Builder WA', href: '/owner-builder-wa' },
      { label: 'CPD for real-estate agents', href: '/cpd' },
    ],
  },
  {
    name: 'Tasmania',
    courses: [
      { label: 'White Card TAS', href: '/white-card-tas' },
      { label: 'Owner Builder TAS', href: '/owner-builder-tas' },
    ],
  },
  {
    name: 'Australian Capital Territory',
    courses: [
      { label: 'White Card ACT', href: '/white-card-act' },
      { label: 'Owner Builder ACT', href: '/owner-builder-act' },
    ],
  },
];

const stateBoard = [
  {
    abbr: 'NSW',
    name: 'New South Wales',
    courses: [
      { label: 'White Card', via: 'AlertForce', href: '/white-card-nsw' },
      { label: 'Owner Builder', via: 'AlertForce', status: 'Coming soon' },
      { label: 'Real Estate CPD', status: 'Coming soon' },
    ],
  },
  {
    abbr: 'QLD',
    name: 'Queensland',
    courses: [
      { label: 'White Card', via: 'Blue Dog', status: 'Coming soon' },
      { label: 'Owner Builder', status: 'Coming soon' },
    ],
  },
  {
    abbr: 'WA',
    name: 'Western Australia',
    courses: [
      { label: 'White Card', via: 'Blue Dog', status: 'Coming soon' },
      { label: 'Owner Builder', status: 'Coming soon' },
    ],
  },
  {
    abbr: 'TAS',
    name: 'Tasmania',
    courses: [
      { label: 'White Card', via: 'Blue Dog', status: 'Coming soon' },
      { label: 'Owner Builder', status: 'Coming soon' },
      { label: 'Builder CPD', status: 'Coming soon' },
      { label: 'Plumber CPD', status: 'Coming soon' },
      { label: 'Electrician CPD', status: 'Coming soon' },
    ],
  },
  {
    abbr: 'ACT',
    name: 'Australian Capital Territory',
    courses: [
      { label: 'White Card', via: 'AlertForce', status: 'Coming soon' },
      { label: 'Owner Builder', status: 'Coming soon' },
      { label: 'Asbestos Awareness', via: 'AlertForce', status: 'Coming soon' },
      { label: 'Silica Awareness', via: 'AlertForce', status: 'Coming soon' },
      { label: 'CPD', status: 'Coming soon' },
    ],
  },
];
---

<div class="space-y-12">
  <section>
    <h3 class="t-label" style="color: var(--color-ink-3);">
      Grid variant (canonical)
    </h3>
    <p
      class="t-body mt-2"
      style="color: var(--color-ink-2); font-size: 14px; max-width: 70ch;"
    >
      A responsive 1px-hairline grid of state cards. Each card is a single
      link to the spoke page; the maroon arrow translates on hover.
    </p>
    <div
      class="mt-3 px-6 py-6"
      style="border: 1px solid var(--color-rule); background: var(--color-bg);"
    >
      <StateNavigator
        heading="Choose your state to find the right Owner Builder course"
        states={states}
      />
    </div>
  </section>

  <section>
    <h3 class="t-label" style="color: var(--color-ink-3);">
      Table variant
    </h3>
    <p
      class="t-body mt-2"
      style="color: var(--color-ink-2); font-size: 14px; max-width: 70ch;"
    >
      A dense State / Regulator / Course row table, in the ComparisonTable
      grammar. Scrolls horizontally on small screens.
    </p>
    <div
      class="mt-3 px-6 py-6"
      style="border: 1px solid var(--color-rule); background: var(--color-bg);"
    >
      <StateNavigator
        heading="Owner Builder courses by state"
        variant="table"
        states={states}
      />
    </div>
  </section>

  <section>
    <h3 class="t-label" style="color: var(--color-ink-3);">
      Links variant
    </h3>
    <p
      class="t-body mt-2"
      style="color: var(--color-ink-2); font-size: 14px; max-width: 70ch;"
    >
      A grid of state cards, each listing several course links. Use on the
      homepage, where one state offers more than one course.
    </p>
    <div
      class="mt-3 px-6 py-6"
      style="border: 1px solid var(--color-rule); background: var(--color-bg);"
    >
      <StateNavigator
        heading="Find your course by state"
        variant="links"
        states={stateLinks}
      />
    </div>
  </section>

  <section>
    <h3 class="t-label" style="color: var(--color-ink-3);">
      Board variant
    </h3>
    <p
      class="t-body mt-2"
      style="color: var(--color-ink-2); font-size: 14px; max-width: 70ch;"
    >
      State-code cards with a per-course status badge. A course with an
      href renders as a dotted link (NSW White Card below); the rest show a
      "Coming soon" badge until the page is published.
    </p>
    <div
      class="mt-3 px-6 py-6"
      style="border: 1px solid var(--color-rule); background: var(--color-bg);"
    >
      <StateNavigator
        heading="Find your course by state"
        variant="board"
        states={stateBoard}
      />
    </div>
  </section>
</div>
