---
/**
 * NumberedStepsSection — H2 + optional intro + N numbered step cards.
 *
 * Variable-length step process: 3 steps on course pages ("How does the
 * course work?"), 5 steps on hub pages ("How to become an owner builder").
 *
 * Each step renders as:
 *   [ 01 ]  Step title
 *           Step body text
 *
 * Number in Display register (mono per the linter-updated .t-display class),
 * Ink-4 colour. Title in custom subheading style. Body in standard Body
 * register. Items separated by 1px dotted ink-3 rules per Two-Ornament Rule.
 *
 * Locked decisions reflected here:
 *   #1 — heading + step titles are props.
 *   #7 — wrapper id auto-generates from slugify(heading).
 */
import { slugify } from '@/lib/slugify';
import AnswerCapsule from '@components/AnswerCapsule/AnswerCapsule.astro';
import BodyParagraph from '@components/BodyParagraph/BodyParagraph.astro';

interface Step {
  title: string;
  text: string;
}

interface Props {
  heading: string;
  /** Optional intro capsule (40–60 words). */
  answer?: string;
  /** Optional intro body (60–120 words). Renders only if `answer` is set. */
  body?: string;
  /** 3–5 step entries. */
  steps: Step[];
  anchorId?: string;
}

const { heading, answer, body, steps, anchorId } = Astro.props;
const id = anchorId ?? slugify(heading);
const hasIntro = Boolean(answer);
---

<section id={id} class="steps">
  <h2 class="t-headline steps__heading">{heading}</h2>

  {hasIntro && <AnswerCapsule text={answer!} />}
  {hasIntro && body && <BodyParagraph text={body} />}

  <ol class="steps__list">
    {
      steps.map((step, i) => (
        <li class="steps__item">
          <span class="steps__num">{String(i + 1).padStart(2, '0')}</span>
          <div class="steps__content">
            <h3 class="steps__title">{step.title}</h3>
            <p class="t-body steps__text">{step.text}</p>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .steps {
    padding: var(--spacing-xxl) 0;
    scroll-margin-top: var(--spacing-xl);
    border-top: 1px solid var(--color-rule);
  }
  .steps__heading {
    color: var(--color-ink);
    text-transform: uppercase;
    margin: 0 0 var(--spacing-lg);
    max-width: 38ch;
  }
  .steps__list {
    list-style: none;
    padding: 0;
    margin: var(--spacing-lg) 0 0;
  }
  .steps__item {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg) 0;
    border-top: 1px dotted var(--color-ink-3);
  }
  .steps__item:last-child {
    border-bottom: 1px dotted var(--color-ink-3);
  }
  .steps__num {
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-ink-4);
    font-feature-settings: "lnum", "tnum";
  }
  .steps__content {
    min-width: 0;
  }
  .steps__title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0 0 var(--spacing-xs);
  }
  .steps__text {
    color: var(--color-ink);
    margin: 0;
    max-width: 65ch;
  }

  @media (max-width: 640px) {
    .steps__item {
      grid-template-columns: 3rem 1fr;
      gap: var(--spacing-md);
    }
    .steps__num {
      font-size: 1.5rem;
    }
  }
</style>
