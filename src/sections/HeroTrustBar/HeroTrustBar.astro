---
/**
 * HeroTrustBar — the slim hero-region credential strip.
 *
 * Analysis §2.1: the "Trust Bar — Hero" that sits directly under the page
 * heading on a hub page. A single colophon-style line — "Recognised by
 * QBCC (QLD) • LGIRS (WA) • ..." — naming the regulators that recognise the
 * courses the hub links to.
 *
 * NOT a Trust Stripe and NOT a stat band. RegulatorBand and the tstrip
 * variants are the heavier between-sections bands (stat tiles, plates);
 * HeroTrustBar is the lightest possible hero credential signal, framed by
 * a 1px Rule line top and bottom.
 *
 * Scope: this is the HUB hero bar. For the course-page hero attribution
 * ("Training delivered by AlertForce (RTO 91826)...") use RTOAttributionLine.
 *
 * Locked decisions reflected here:
 *   #1 — heading is a prop, rendered as a visually-hidden <h2> so the strip
 *        keeps a document-outline entry without a visible title.
 *   #7 — wrapper id auto-generates from slugify(heading).
 */
import { slugify } from '@/lib/slugify';

interface Credential {
  /** Regulator or authority name, e.g. "QBCC", "NSW Fair Trading". */
  regulator: string;
  /** Optional jurisdiction tag, e.g. "QLD". Rendered in parentheses. */
  state?: string;
}

interface Props {
  /** Accessible section label (visually hidden). e.g. "Course recognition". */
  heading: string;
  /** Lead-in label. */
  label?: string;
  /** The regulators that recognise the hub's courses. */
  credentials: Credential[];
  anchorId?: string;
}

const { heading, label = 'Recognised by', credentials, anchorId } = Astro.props;
const id = anchorId ?? slugify(heading);
---

<section id={id} class="htb-section" aria-labelledby={`${id}-label`}>
  <h2 id={`${id}-label`} class="sr-only">{heading}</h2>
  <p class="htb">
    <span class="htb__label">{label}</span>
    {
      credentials.map((c, i) => (
        <>
          {i > 0 && <span class="htb__sep" aria-hidden="true">•</span>}
          <span class="htb__cred">
            {c.regulator}
            {c.state && <span class="htb__state"> ({c.state})</span>}
          </span>
        </>
      ))
    }
  </p>
</section>

<style>
  /* A slim colophon strip — 1px Rule line top and bottom, no fill. The
     lightest member of the trust family; the heavier stat bands are
     RegulatorBand and the tstrip variants. */
  .htb-section {
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    padding: var(--spacing-sm) 0;
    scroll-margin-top: var(--spacing-xl);
  }

  .htb {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5em;
    line-height: 1.6;
  }

  /* Lead-in label — 10px Geist Mono caps, Ink-3, the verification register. */
  .htb__label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-3);
  }

  /* Each regulator credential — Public Sans body, Ink-2. */
  .htb__cred {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    color: var(--color-ink-2);
  }

  .htb__state {
    color: var(--color-ink-3);
  }

  /* Double-spaced bullet separator, Ink-4 — the trust-family separator. */
  .htb__sep {
    font-size: 12px;
    color: var(--color-ink-4);
  }
</style>
