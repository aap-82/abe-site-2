---
/**
 * FAQSection — frameless accordion.
 *
 * No surrounding ink card; each item is separated by a 1px solid ink top
 * divider. The toggle indicator swaps between `+` (closed) and `×` (open)
 * in Maroon. Hover shifts the question text to Maroon (no background flash).
 *
 * Native HTML <details>/<summary>: multi-open by default, no JavaScript,
 * full keyboard accessibility.
 *
 * Drives the FAQPage JSON-LD via the same `items` array.
 *
 * Locked decisions reflected here:
 *   #1 — question texts are props.
 *   #7 — wrapper id auto-generates from slugify(heading) when provided.
 */
import { slugify } from '@/lib/slugify';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  /**
   * Optional heading. Not rendered — used only as the basis for the wrapper
   * id when `anchorId` is not provided.
   */
  heading?: string;
  /** 6–10 question/answer pairs. */
  items: FAQItem[];
  /** Override the wrapper id. */
  anchorId?: string;
}

const { heading, items, anchorId } = Astro.props;
const id = anchorId ?? (heading ? slugify(heading) : 'faq');
---

<section id={id} class="faqs-section">
  <div class="faqs">
    {
      items.map((item) => (
        <details class="faq">
          <summary class="faq__summary">
            <h3 class="faq__q">{item.question}</h3>
            <span class="faq__indicator" aria-hidden="true">
              {/* Plus icon — visible when [open] is absent */}
              <svg
                class="faq__icon faq__icon--plus"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <line x1="5" y1="12" x2="19" y2="12" />
                <line x1="12" y1="5" x2="12" y2="19" />
              </svg>
              {/* Close icon — visible when [open] is set */}
              <svg
                class="faq__icon faq__icon--close"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <line x1="6" y1="6" x2="18" y2="18" />
                <line x1="18" y1="6" x2="6" y2="18" />
              </svg>
            </span>
          </summary>
          <div class="faq__answer">
            <p>{item.answer}</p>
          </div>
        </details>
      ))
    }
  </div>
</section>

<style>
  .faqs-section {
    padding: var(--spacing-xxl) 0;
    scroll-margin-top: var(--spacing-xl);
  }

  /* Outer outline — heavy 1px solid Ink top and bottom only.
     No side borders, no background. */
  .faqs {
    border-top: 1px solid var(--color-ink);
    border-bottom: 1px solid var(--color-ink);
  }

  /* Inner dividers between items — lighter 1px solid Rule.
     First child has no top divider (the outer outline handles it). */
  .faq + .faq {
    border-top: 1px solid var(--color-rule);
  }

  .faq__summary {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--spacing-md);
    align-items: center;
    padding: var(--spacing-md) 0;
  }
  .faq__summary::-webkit-details-marker {
    display: none;
  }
  .faq__summary:focus-visible {
    outline: 2px solid var(--color-ink);
    outline-offset: 2px;
  }

  .faq__q {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.05rem, 1.5vw, 1.15rem);
    letter-spacing: -0.005em;
    color: var(--color-ink);
    margin: 0;
    transition: color 180ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .faq__summary:hover .faq__q,
  .faq__summary:focus-visible .faq__q {
    color: var(--color-accent);
  }

  /* Indicator slot — shared sizing for both icons */
  .faq__indicator {
    width: 18px;
    height: 18px;
    display: inline-block;
    flex-shrink: 0;
    position: relative;
  }

  .faq__icon {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--color-accent);
    stroke: currentColor;
    fill: none;
    stroke-width: 1.75;
    stroke-linecap: round;
    transition: color 180ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Closed state: show + */
  .faq__icon--plus { display: block; }
  .faq__icon--close { display: none; }

  /* Open state: swap to × */
  .faq[open] .faq__icon--plus { display: none; }
  .faq[open] .faq__icon--close { display: block; }

  .faq__summary:hover .faq__icon {
    color: var(--color-accent-deep);
  }

  .faq__answer {
    padding: 0 0 var(--spacing-lg);
    max-width: 70ch;
  }
  .faq__answer p {
    margin: 0 0 var(--spacing-sm);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-ink-2);
  }
  .faq__answer p:last-child {
    margin: 0;
  }
</style>
