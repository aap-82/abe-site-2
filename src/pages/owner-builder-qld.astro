---
/**
 * /owner-builder-qld — the QLD Owner Builder course-state page.
 *
 * Built from library components, two-file architecture: SEO meta in
 * src/content/pages-course-state/owner-builder-qld.md, the composition here.
 *
 * AUTHORITY MODEL — ABE-DIRECT (confirmed by Andrey, 22 May 2026).
 * ABE Education's own course, recognised by QBCC. No RTO partner, so the
 * `disclosure` context is omitted: no RTOAttributionLine, no ASQA disclosure.
 * `provider` in the schema is ABE Education.
 *
 * BUILD STATUS — HOLD before publish. Three gates, all carried from the
 * source draft (owner-builder-qld.md v0.9):
 *   1. QBCC approval pending. `noIndex` is set so the page is not indexed
 *      until approval lands. Every approval-dependent claim uses the
 *      pre-approval-safe wording (see the "Why choose" item and the
 *      "Who approves this course?" FAQ).
 *   2. ABE course price unconfirmed. The PricingTable row shows a visible
 *      [TO VERIFY] placeholder — replace before publish.
 *   3. No `reviewer` is passed. Warwick Smith's QLD compliance and currency
 *      review is not yet complete, so only the freshness date renders.
 *
 * RECONCILIATION NOTE: the source draft flags that Dominic Ogburn's verified
 * Notion record still describes the QLD course as Edway co-delivery. Building
 * ABE-direct per Andrey's decision; the Notion record must be updated to match
 * before publish, or this page flipped to the RTO-partner pattern.
 *
 * Fidelity note: the source draft's "can / cannot" two-list table is rendered
 * as a ComparisonTable (the library has no two-column-list component); rows are
 * grouped by work area so every cell carries content.
 */
import { getEntry } from 'astro:content';
import CoursePageLayout from '@layouts/CoursePageLayout/CoursePageLayout.astro';
import AnswerCapsuleSection from '@sections/AnswerCapsuleSection/AnswerCapsuleSection.astro';
import NumberedStepsSection from '@sections/NumberedStepsSection/NumberedStepsSection.astro';
import WhyChooseList from '@sections/WhyChooseList/WhyChooseList.astro';
import ComparisonTable from '@sections/ComparisonTable/ComparisonTable.astro';
import PricingTable from '@sections/PricingTable/PricingTable.astro';
import FAQSection from '@sections/FAQSection/FAQSection.astro';
import BodyParagraph from '@components/BodyParagraph/BodyParagraph.astro';
import VerificationNote from '@components/VerificationNote/VerificationNote.astro';
import SourceCitation from '@components/SourceCitation/SourceCitation.astro';
import WarningCallout from '@components/WarningCallout/WarningCallout.astro';
import LegalCallout from '@components/LegalCallout/LegalCallout.astro';
import CrossRefLink from '@components/CrossRefLink/CrossRefLink.astro';
import ExpertReviewerCard from '@components/ExpertReviewerCard/ExpertReviewerCard.astro';

const entry = await getEntry('pages-course-state', 'owner-builder-qld');
if (!entry) throw new Error('Missing content entry: pages-course-state/owner-builder-qld');
const meta = entry.data;

// QBCC source URLs — verified against qbcc.qld.gov.au on 22 May 2026.
const QBCC_ABOUT = 'https://www.qbcc.qld.gov.au/home-owner-hub/owner-build/about-owner-building';
const QBCC_COURSES = 'https://www.qbcc.qld.gov.au/home-owner-hub/owner-build/required-courses-owner-builders';
const QBCC_APPLY = 'https://www.qbcc.qld.gov.au/home-owner-hub/owner-build/apply-owner-builder-permit';

const courseSteps = [
  {
    title: 'Enrol online',
    text: 'Sign up and start straight away. The course is 100% online and self-paced, so you can fit it around work and family.',
  },
  {
    title: 'Work through the modules',
    text: 'Cover the knowledge a Queensland owner builder needs: your responsibilities, the building approval process, contracts and trades, work health and safety, and what you can and cannot do under a permit.',
  },
  {
    title: 'Complete the assessment',
    text: 'Finish the assessment inside the platform to receive your Certificate of Completion.',
  },
  {
    title: 'Apply to QBCC for your permit',
    text: 'Submit your permit application to QBCC with your certificate, which must be no more than 5 years old. Your permit must be approved before any work starts on site.',
  },
];

const learningOutcomes = [
  { text: 'Your legal responsibilities as a Queensland owner builder' },
  { text: 'The building approval and certification process' },
  { text: 'How to engage and coordinate licensed trades' },
  { text: 'Work health and safety obligations on a residential site' },
  { text: 'Managing contracts, costs and variations' },
  { text: 'How to avoid the common mistakes that lead to defects and disputes' },
];

const scopeRows = [
  {
    label: 'Building new',
    cells: [
      'Build a new home, garage, carport or shed on your own land',
      'Build commercial, industrial or farm buildings',
    ],
  },
  {
    label: 'Renovating',
    cells: [
      'Renovate, alter or extend your existing home',
      'Build or renovate multiple dwellings such as duplexes, units or granny flats',
    ],
  },
  {
    label: 'Outdoor projects',
    cells: [
      'Build a residential pool, pergola or entertainment area',
      'Remove more than 10 square metres of asbestos',
    ],
  },
  {
    label: 'Continuing a build',
    cells: [
      'Complete a home from a stage built by a licensed builder',
      'Carry out fire-protection or mechanical-services work over $1,100 without a licence',
    ],
  },
  {
    label: 'Specialist trades',
    cells: [
      'Coordinate licensed trades across the whole project',
      'Carry out plumbing, drainage or gas fitting yourself without a licence',
    ],
  },
];

const pricingRows = [
  { item: 'ABE owner builder course (QLD)', cost: '[TO VERIFY: ABE price]' },
  {
    item: 'QBCC owner builder permit application fee',
    cost: '$477.47',
    costHref: QBCC_APPLY,
  },
];

const whyItems = [
  { title: '100% online and self-paced', text: 'start today and study around work and family' },
  { title: 'Written by a licensed builder', text: 'real residential construction experience behind every module' },
  { title: 'Independently reviewed for currency', text: 'legislation and regulator details are kept up to date' },
  { title: 'Built for the QBCC requirement', text: "designed to meet QBCC's owner builder course requirement" },
];

const faqs = [
  {
    question: 'Do I need an owner builder course in Queensland?',
    answer: 'Most people do. Unless you qualify for a QBCC exemption, for example you hold a current QBCC licence or certain professional qualifications, you must complete an approved owner builder course before you apply for your permit.',
  },
  {
    question: 'When do I need an owner builder permit?',
    answer: "You need a permit for owner building work valued at more than $11,000 on your own land, company-owned land if you are a director, or land you lease with the owner's permission. Farm buildings have a higher threshold of $27,500.",
  },
  {
    question: 'How long is my course certificate valid?',
    answer: 'Your owner builder course certificate must be no more than 5 years old when you apply to QBCC for your permit. If your certificate is older than that, you will need to complete the course again before you can apply.',
  },
  {
    question: 'How long does the course take?',
    answer: 'The course is online and self-paced, so the timing is up to you. Most learners complete it over a few sittings, fitting study around work and family. There is no set deadline once you enrol.',
  },
  {
    question: 'Can I get the Queensland Home Warranty Scheme as an owner builder?',
    answer: 'No. Owner builders cannot access the Queensland Home Warranty Scheme. That cover protects home owners who contract a licensed builder, so it is worth weighing up before you decide to owner build.',
  },
  {
    question: 'How often can I be an owner builder?',
    answer: 'QBCC can issue you only one owner builder permit every 6 years, though exemptions are sometimes granted. If you have held a permit recently, check your eligibility with QBCC before you enrol.',
  },
  {
    question: 'Who approves this course?',
