---
/**
 * BaseLayout — every content page on the abe-site wraps in this layout.
 *
 * Responsibilities:
 *   - Set up <html lang="en-AU">, charset, viewport
 *   - Render <title>, meta description, canonical, OG tags
 *   - Load global.css (which loads fonts + tokens + type classes)
 *   - Provide a <slot name="schema" /> for layout-specific JSON-LD
 *   - Provide a default <slot /> for the page body
 *
 * Archetype layouts (HomepageLayout, HubLayout, CoursePageLayout) wrap this
 * layout and inject their own schema graph plus their archetype-specific
 * sections. This layout never renders schema itself.
 *
 * Locked decisions reflected here:
 *   #5 — schema is injected per-layout via the <slot name="schema" />
 *   #6 — lastUpdated is owned by frontmatter; this layout doesn't read it
 *        (PageHeading does)
 */
import '@/styles/global.css';
import SiteMapBar from '@components/SiteMapBar/SiteMapBar.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  /** Hide from search engines (use on styleguide, drafts, internal pages). */
  noIndex?: boolean;
}

const { title, description, canonical, ogImage, noIndex } = Astro.props;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Google Fonts — explicit <link> in head so they load in parallel
         with HTML, not deferred behind the global.css @import. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Geist+Mono:wght@400;500;600;700&family=Public+Sans:wght@400;500;600;700&family=Source+Serif+4:wght@400;500;600;700&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Archetype layouts inject their JSON-LD into this slot. -->
    <slot name="schema" />
  </head>
  <body>
    <SiteMapBar />
    <slot />
  </body>
</html>
